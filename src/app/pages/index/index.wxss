/* 环境数据网格 */
.env-grid {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.env-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 160rpx;
  padding: 16rpx 0;
}

.env-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.env-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.env-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 雷达数据行 */
.radar-row {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.radar-badge {
  font-size: 26rpx;
  background: #e6f7ff;
  color: #1890ff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 告警文本 */
.alarm-text {
  color: #ff4d4f;
  font-size: 30rpx;
}

.normal-text {
  color: #888;
  font-size: 28rpx;
}

/* 事件行 */
.event-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.event-row:last-child {
  border-bottom: none;
}

.event-type {
  font-size: 28rpx;
  font-weight: bold;
  min-width: 100rpx;
  color: #333;
}

.event-title {
  flex: 1;
  font-size: 28rpx;
  margin: 0 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #555;
}

.event-time {
  font-size: 24rpx;
  color: #aaa;
  min-width: 100rpx;
  text-align: right;
}

/* ── 书架可视化 — 精准距离竖排书脊 ───────────────────── */

.shelf-layer-v {
  margin-bottom: 20rpx;
}

.shelf-layer-v:last-child {
  margin-bottom: 0;
}

.shelf-layer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.shelf-layer-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.shelf-layer-count {
  font-size: 24rpx;
  color: #2d8cf0;
  background: #e6f7ff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 书架轨道 — 38cm 按比例 */
.shelf-track-v {
  position: relative;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  border-bottom: 6rpx solid #d0c8b0;
  overflow: hidden;
}

/* 单本书脊 — 绝对定位，精确匹配 cm 位置 */
.spine-book-v {
  position: absolute;
  top: 0;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4rpx 4rpx 2rpx 2rpx;
  box-sizing: border-box;
  border-right: 2rpx solid rgba(255,255,255,0.3);
  box-shadow: inset 0 8rpx 4rpx rgba(255,255,255,0.2), 1rpx 0 3rpx rgba(0,0,0,0.1);
  overflow: hidden;
}

/* 竖排书名 */
.spine-title-v {
  writing-mode: vertical-rl;
  text-orientation: mixed;
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
  letter-spacing: 3rpx;
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.4);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-height: 92%;
  padding: 4rpx 2rpx;
  pointer-events: none;
}

/* 距离刻度 */
.shelf-ticks-v {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #bbb;
  margin-top: 6rpx;
  padding: 0 2rpx;
}

/* 图例 */
.shelf-legend-v {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #888;
}

.legend-dot-v {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
  margin-right: 8rpx;
  margin-left: 24rpx;
}

.legend-dot-v:first-child {
  margin-left: 0;
}

/* ── 数据来源标签 ──────────────────────────────────────── */

.data-source {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid #f0f0f0;
}

.source-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  color: #888;
  background: #f5f5f5;
}

.source-tag.cloud {
  color: #2d8cf0;
  background: #e6f7ff;
}

.source-tag.mqtt {
  color: #52c41a;
  background: #f6ffed;
}

/* ── 24h 趋势图 ────────────────────────────────────────── */

.trend-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.trend-card {
  padding: 22rpx 22rpx 18rpx;
  border-radius: 16rpx;
  background: #fafbfd;
  border: 2rpx solid #eef2f6;
}

.trend-card.temp {
  background: linear-gradient(180deg, #fff8f7 0%, #ffffff 100%);
}

.trend-card.hum {
  background: linear-gradient(180deg, #f7fbff 0%, #ffffff 100%);
}

.trend-card.lux {
  background: linear-gradient(180deg, #fffbf3 0%, #ffffff 100%);
}

.trend-card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.trend-card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2f3440;
}

.trend-card-range {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #97a1b2;
}

.trend-card-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #4b5565;
}

.trend-canvas {
  display: block;
  width: 100%;
  height: 320rpx;
}

/* ── 7 天摘要 ──────────────────────────────────────────── */

.summary-grid {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-val {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.summary-sub {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.suggestions {
  border-top: 2rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.suggestion-item {
  font-size: 26rpx;
  color: #555;
  padding: 10rpx 0;
  padding-left: 16rpx;
  border-left: 4rpx solid #faad14;
  margin-bottom: 8rpx;
  background: #fffbe6;
  border-radius: 0 8rpx 8rpx 0;
}
